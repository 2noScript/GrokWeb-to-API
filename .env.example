# Grok API Configuration

# API Server Configuration
GROK_API_URL=http://127.0.0.1:8000

# Grok Model Configuration
MODEL_NAME=grok-4.3

# Authentication Cookies
# Option 1: Auto-generated from browser via get_cookies.py (recommended)
# Run: poetry run python get_cookies.py
# After login, cookies are saved to grok_cookies.json in project root.
# The client will auto-load grok_cookies.json, no env vars needed.

# Option 2: Manual env cookies
# Replace these with your actual Grok cookies from browser after login
# GROK_SSO=your_sso_cookie_value_here
# GROK_SSO_RW=your_sso_rw_cookie_value_here

# Option 3: Explicit cookie file path
# GROK_COOKIES_JSON=/path/to/grok_cookies.json

# Proxy Configuration (optional)
# Proxy URL for HTTP/HTTPS/SOCKS5 requests.
# Examples:
#   HTTP proxy:  http://proxy.example.com:8080
#   HTTPS proxy: https://proxy.example.com:8443
#   SOCKS5:      socks5://proxy.example.com:1080
# PROXY_URL=http://127.0.0.1:8080
# If the proxy requires authentication, also set:
# PROXY_USERNAME=proxy_user
# PROXY_PASSWORD=proxy_password

# Optional: bypass proxy for specific domains (comma-separated).
# Applications use NO_PROXY; verify_login uses PROXY_BYPASS.
# Example: NO_PROXY=google.com,gstatic.com,accounts.google.com
